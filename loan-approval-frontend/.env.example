# ============================================================
# Loan Approval System - Frontend Environment Variables
# ============================================================
# Copy this file to .env and update the values as needed.
# cp .env.example .env
# ============================================================
#
# NOTE: Vite requires environment variables to be prefixed
# with VITE_ to be exposed to the client-side code.
# ============================================================


# ---- Uploads URL ------------------------------------------------
# Base URL for accessing uploaded files (e.g., PDF previews)
# This can be a full URL (including port) or a relative path.
# If using the Vite dev server proxy, leave this empty and
# the proxy will handle /uploads requests.
# Default: '' (empty - uses relative path via proxy)
# Example: http://localhost:8080
VITE_UPLOADS_URL=


# ---- Logging Configuration --------------------------------------
# Log level for frontend browser console logging
# Available levels (in order of verbosity):
#   debug  - Most verbose, includes all diagnostic info
#   info   - Normal operational messages (default)
#   warn   - Only warnings and errors
#   error  - Only error messages
#   fatal  - Only critical/fatal errors
VITE_LOG_LEVEL=info

# Optional: Backend endpoint URL to which error logs are sent
# When set, all ERROR and FATAL level logs will be POSTed
# to this endpoint for centralized error collection.
# Leave empty to disable remote logging.
# Example: /api/log
VITE_LOG_ENDPOINT=/api/log


# ---- API Configuration ------------------------------------------
# Base URL for the backend API (usually proxied via Vite)
# The Vite dev server proxies /api/* requests to the backend.
# In production, set this to the actual backend URL.
# Default: '' (empty - uses relative path via proxy)
# Example: http://localhost:8080
VITE_API_URL=

