# ============================================================
# Loan Approval System - Java (Spring Boot) Backend
# Environment Variables
# ============================================================
# Copy this file to .env and update the values as needed.
# Spring Boot automatically loads .env variables when using
# spring-boot-starter with dotenv support.
# Alternatively, set these as system environment variables.
# ============================================================


# ─── Server Configuration ────────────────────────────────────
# Port on which the Spring Boot backend server will run
# Default: 8080
SERVER_PORT=8080


# ─── Database Connection (PostgreSQL) ────────────────────────
# Hostname/address of the PostgreSQL database server
# Default: localhost
DB_HOST=localhost

# Port of the PostgreSQL database server
# Default: 5432
DB_PORT=5432

# Name of the PostgreSQL database
# Default: loan_approval_db
DB_NAME=loan_approval_db

# PostgreSQL database username (REQUIRED)
DB_USERNAME=postgres

# PostgreSQL database password (REQUIRED)
DB_PASSWORD=1234


# ─── JWT Configuration ───────────────────────────────────────
# Secret key for signing JWT tokens (REQUIRED)
# Must be a Base64-encoded string of at least 256 bits (32 bytes)
# Generate using: openssl rand -base64 32
# The application reads this from application.properties as
# app.jwt.secret property
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970337336763979244226452948404D635166546A576E5A7234753778214125442A47

# JWT token expiration time in milliseconds
# Default: 86400000 (24 hours)
JWT_EXPIRATION_MS=86400000


# ─── File Upload Configuration ───────────────────────────────
# Directory to store uploaded PDF files
# Path is relative to the project root
FILE_UPLOAD_DIR=uploads

# Maximum file size for uploads (in bytes)
# Default: 20971520 (20 MB)
FILE_MAX_SIZE=20971520


# ─── Email (SMTP) Configuration ──────────────────────────────
# SMTP host for sending email notifications
# Default: smtp.gmail.com
MAIL_HOST=smtp.gmail.com

# SMTP server port
# Default: 587 (TLS)
MAIL_PORT=587

# SMTP username (usually an email address)
# Leave empty if not using email notifications
MAIL_USERNAME=

# SMTP password or app-specific password
# For Gmail, use an App Password (not your regular password)
# Leave empty if not using email notifications
MAIL_PASSWORD=


# ─── Logging Configuration ───────────────────────────────────
# Log level for the application
# Available levels: TRACE, DEBUG, INFO, WARN, ERROR, FATAL
# Default: INFO
LOG_LEVEL=INFO

# Log level specifically for SQL queries (Hibernate)
# Default: WARN
LOG_LEVEL_SQL=WARN

# Directory for storing log files
LOG_PATH=../logs


# ─── LLM / AI Configuration ──────────────────────────────────
# API keys for LLM providers - override values in llm.json:
#   LLM_GEMINI_API_KEY       - For Google Gemini
#   LLM_OPENAI_API_KEY       - For OpenAI
#   LLM_ANTHROPIC_API_KEY    - For Anthropic/Claude
#   LLM_API_KEY              - Generic fallback for any provider
#   GEMINI_API_KEY           - Legacy fallback for Gemini
#
# Example:
# LLM_GEMINI_API_KEY=your-api-key-here

# ============================================================
# NOTE: The actual application.properties file uses these
# environment variables as overrides. Set them here or in
# your system environment.
# ============================================================
