# Database connection (REQUIRED)
DATABASE_URL=postgresql://user:password@localhost:5432/loan_approval

# Server
PORT=8080

# Logging
LOG_LEVEL=info
LOG_PATH=../logs

# JWT Secret
JWT_SECRET=change-this-to-a-random-secret

# LLM Configuration (optional - edit llm.json instead for most settings)
# Override any API key from llm.json without putting keys in the JSON file:
# LLM_OPENAI_API_KEY=sk-...
# LLM_ANTHROPIC_API_KEY=sk-ant-...
# LLM_GEMINI_API_KEY=AIza...
# LLM_API_KEY=... (fallback for openai-compatible provider)
