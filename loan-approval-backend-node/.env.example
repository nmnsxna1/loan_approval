# ============================================================
# Loan Approval System - Node.js Backend Environment Variables
# ============================================================
# Copy this file to .env and update the values as needed.
# cp .env.example .env
# ============================================================
#
# NOTE: This file contains sensitive configuration (passwords, secrets).
# Never commit the actual .env file to version control!
# ============================================================


# ---- Database Connection ---------------------------------------
# PostgreSQL connection string (REQUIRED)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
# Example: postgresql://postgres:mysecret@localhost:5432/loan_approval_db
DATABASE_URL="postgresql://postgres:1234@localhost:5432/loan_approval_db"


# ---- Server Configuration --------------------------------------
# Port on which the backend server will run
# Default: 8080 (must match the frontend proxy configuration)
PORT=8080

# Comma-separated list of allowed CORS origins
# Default: http://localhost:3000, http://localhost:3001, http://localhost:5173
# In production, set this to your actual frontend domain(s)
# Example: https://myapp.com, https://admin.myapp.com
CORS_ORIGINS=http://localhost:3000, http://localhost:3001, http://localhost:5173


# ---- JWT (JSON Web Token) Configuration ------------------------
# Secret key used to sign and verify JWT tokens (REQUIRED)
# Generate a strong random secret using:
#   - openssl rand -base64 64
#   - node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# WARNING: If this is not set, the server will throw an error on startup
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970337336763979244226452948404D635166546A576E5A7234753778214125442A47

# JWT token expiration time (optional)
# Format: Numeric string with time unit suffix
# Values: 24h (24 hours), 7d (7 days), 3600 (seconds)
# Default: 24h
JWT_EXPIRES_IN=24h


# ---- File Upload Configuration ---------------------------------
# Directory where uploaded PDF files will be stored
# Path is relative to the project root directory
# Default: uploads
UPLOAD_DIR=uploads


# ---- Logging Configuration -------------------------------------
# Log level controls the verbosity of log output
# Available levels (in order of verbosity):
#   debug  - Most verbose, includes all diagnostic info
#   info   - Normal operational messages (default)
#   warn   - Only warnings and errors
#   error  - Only error messages
#   fatal  - Only critical/fatal errors
LOG_LEVEL=info

# Directory where log files will be written
# Path is relative to the project root directory
# Default: ../logs (one level above project root)
LOG_PATH=../logs


# ---- LLM / AI Provider Configuration ---------------------------
# API keys for LLM providers can be set via environment variables.
# These override the keys specified in llm.json:
#   LLM_OPENAI_API_KEY       - For OpenAI provider
#   LLM_ANTHROPIC_API_KEY    - For Anthropic/Claude provider
#   LLM_GEMINI_API_KEY       - For Google Gemini provider
#   LLM_API_KEY              - Generic fallback for any provider
#
# If not set here, the values from llm.json will be used.
# Example:
# LLM_GEMINI_API_KEY=your-gemini-api-key-here
# LLM_OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# NOTE: Additional variables can be added as needed.
# The application reads environment variables at startup.
# ============================================================
